# Environment Configuration Example
# Copy this file to .env and update with your values

# Environment: dev, staging, production
ENV=production

# API Base URL
# Production (Domain with HTTPS)
API_BASE_URL=https://api.buildwithardan.my.id

# Development Options:
# API_BASE_URL=http://10.0.2.2:8000  # Android Emulator
# API_BASE_URL=http://localhost:8000  # iOS Simulator
# API_BASE_URL=http://192.168.x.x:8000  # Real device on same network

# Firebase Configuration (if needed)
# FIREBASE_API_KEY=your_api_key
# FIREBASE_PROJECT_ID=your_project_id
